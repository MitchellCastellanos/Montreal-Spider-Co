// Montreal Spider Co. — database schema (Neon Postgres)
// Run `npx prisma generate` after changes, and `npx prisma migrate deploy`
// (or `npx prisma db push`) to apply to your database. See SETUP_DATABASE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Experience {
  beginner
  intermediate
  advanced
}

enum SpiderType {
  terrestrial
  arboreal
  fossorial
}

enum Temperament {
  docile
  skittish
  defensive
}

/** Reusable species profile — fill once, reuse across listings. */
model Species {
  id            String       @id @default(cuid())
  scientific    String       @unique
  commonEn      String
  commonFr      String       @default("")
  genus         String
  experience    Experience
  type          SpiderType
  temperament   Temperament
  hue           Int          @default(36)
  accent        String       @default("#c9a24b")
  image         String?
  adultSizeEn   String       @default("")
  adultSizeFr   String       @default("")
  growthEn      String       @default("")
  growthFr      String       @default("")
  originEn      String       @default("")
  originFr      String       @default("")
  lifespanEn    String       @default("")
  lifespanFr    String       @default("")
  humidity      String       @default("")
  temperature   String       @default("")
  enclosureEn   String       @default("")
  enclosureFr   String       @default("")
  dietEn        String       @default("")
  dietFr        String       @default("")
  descriptionEn String       @default("")
  descriptionFr String       @default("")
  careGuide     String?
  products      Product[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([genus])
  @@index([commonEn])
}

model Product {
  id            String       @id @default(cuid())
  slug          String       @unique
  scientific    String
  speciesId     String?
  species       Species?     @relation(fields: [speciesId], references: [id], onDelete: SetNull)
  commonEn      String
  commonFr      String
  genus         String
  experience    Experience
  type          SpiderType
  temperament   Temperament
  featured      Boolean      @default(false)
  newArrival    Boolean      @default(false)
  hue           Int          @default(36)
  accent        String       @default("#c9a24b")
  image         String?
  adultSizeEn   String       @default("")
  adultSizeFr   String       @default("")
  growthEn      String       @default("")
  growthFr      String       @default("")
  originEn      String       @default("")
  originFr      String       @default("")
  lifespanEn    String       @default("")
  lifespanFr    String       @default("")
  humidity      String       @default("")
  temperature   String       @default("")
  enclosureEn   String       @default("")
  enclosureFr   String       @default("")
  dietEn        String       @default("")
  dietFr        String       @default("")
  descriptionEn String       @default("")
  descriptionFr String       @default("")
  careGuide     String?
  arrived                DateTime     @default(now())
  /** Fulfillment from warehouse stock (delivery or pickup). */
  availableAtPickup      Boolean      @default(true)
  /** Also offered through authorized distributors (separate stock). */
  availableAtDistributor Boolean      @default(false)
  /** When true, the storefront hides this listing once it has zero stock everywhere (vs. showing a "Sold out" badge). */
  hideWhenSoldOut        Boolean      @default(false)
  /** @deprecated unused — availability/price now comes from Specimen rows. */
  sizes                  ProductSize[]
  distributorStocks      ProductDistributorStock[]
  specimens              Specimen[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([experience])
  @@index([genus])
  @@index([speciesId])
}

/** @deprecated Tier pricing/stock is replaced by per-specimen sizeCm/sex/price. Kept (unused) until the backfill below is verified, then dropped in a follow-up. */
model ProductSize {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  key       String
  labelEn   String
  labelFr   String
  /** Minimum leg span in inches (filterable; 0.125 = 1/8″). */
  sizeMinInches Float @default(0.125)
  /** Maximum leg span in inches. */
  sizeMaxInches Float @default(0.25)
  price     Float
  stock     Int     @default(0)
  position  Int     @default(0)

  @@index([productId])
  @@index([sizeMinInches])
  @@index([sizeMaxInches])
}

/**
 * A physical location MSC operates through. Capabilities (pickup, consignment, …)
 * are independent flags — a location may support any combination. Partners never
 * own inventory: specimens located here still belong to Montreal Spider Co.
 */
model StoreLocation {
  id            String   @id @default(cuid())
  name          String
  neighborhood  String   @default("")
  address       String
  hours         Json     @default("{}")
  mapsUrl       String   @default("")
  phone         String   @default("")
  position      Int      @default(0)
  active        Boolean  @default(true)
  /** Capability: customers can collect web orders here. */
  isPickup      Boolean  @default(false)
  /** Capability: holds MSC consignment inventory for walk-in sales. */
  isDistributor Boolean  @default(false)
  /** Partner contact email — used for all partner operations notifications. */
  email         String   @default("")
  contactName   String   @default("")
  whatsapp      String   @default("")
  /** Unguessable token embedded in QR codes / links so partners can use simple confirmation pages without accounts. */
  partnerToken  String   @unique @default(cuid())
  /** Minimum retail price policy (%) relative to MSRP that partners must respect. 100 = never below MSRP. */
  minPricePct   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  distributorStock ProductDistributorStock[]
  consignmentSpecimens Specimen[]
  fulfillments     Fulfillment[]
  audits           StoreAudit[]
  restockProposals RestockProposal[]
  settlementEntries SettlementEntry[]
  settlementStatements SettlementStatement[]
  tasks            OperationsTask[]
}

model ProductDistributorStock {
  id         String        @id @default(cuid())
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   StoreLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  stock      Int           @default(0)
  /** Admin-only reminder / wholesale price at this distributor — never shown on the storefront. */
  distributorPrice Float?

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
}

/** Bilingual key/value store for store policies (pickup terms, T&C). */
model Setting {
  key     String @id
  valueEn String @default("")
  valueFr String @default("")
}

/** Key/value store for admin-managed site options (e.g. default product photo). */
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/** Reusable species photos uploaded from the admin — searchable when assigning product images. */
model SpeciesLibraryImage {
  id         String   @id @default(cuid())
  url        String
  label      String   @default("")
  scientific String   @default("")
  genus      String   @default("")
  slug       String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())

  @@index([scientific])
  @@index([genus])
  @@index([label])
}

// ---------------------------------------------------------------------------
// Customers, orders & checkout (production)
// ---------------------------------------------------------------------------

enum OrderStatus {
  /** Stripe payment succeeded — specimens are allocated, fulfillment not started. */
  paid
  processing
  ready
  delivered
  cancelled
}

enum FulfillmentMethod {
  delivery
  pickup
}

enum SpecimenStatus {
  available
  /** @deprecated location is no longer a status — legacy rows are backfilled to `available` + locationType `consignment`. */
  consignment
  /** Reserved for a paid order; hidden from the storefront until delivered or released. */
  allocated
  sold
  written_off
}

enum SpecimenLocationType {
  warehouse
  /** Physically at a partner store (MSC still owns the specimen). */
  consignment
  /** In transit between locations (e.g. restock delivery). */
  transit
}

enum SalesChannel {
  web
  pickup_counter
  kijiji
  marketplace
  distributor
  event
  wholesale
  other
}

enum PaymentMethod {
  stripe
  cash
  e_transfer
  other
}

enum InventoryMovementType {
  purchase
  transfer
  sale
  write_off
  /** Reserved for a paid order (available → allocated). */
  allocation
  /** Released back to available (cancellation / no-show). */
  release
  /** Inventory correction from a store audit. */
  correction
}

enum SpecimenSex {
  unsexed
  male
  female
}

/** Individual tarantula — source of truth for inventory, pricing & accounting. */
model Specimen {
  id              String               @id @default(cuid())
  productId       String
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  /** @deprecated legacy tier key — kept for old rows, no longer written by new code. */
  sizeKey         String?
  /** Exact leg span in cm, entered at intake; UI derives inches/eighths for display. */
  sizeCm          Float                @default(0)
  sex             SpecimenSex          @default(unsexed)
  /** Asking/listing price while available (distinct from `salePrice`, the price it actually sold for). */
  price           Float                @default(0)
  /** Per-specimen photo override; falls back to the product/species photo when null. */
  photoUrl        String?
  /** TarantulApp Verified Origin ID — optional until registered manually. */
  tarantulAppId   String?              @unique
  status          SpecimenStatus       @default(available)
  locationType    SpecimenLocationType @default(warehouse)
  locationId      String?
  location        StoreLocation?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  /** Internal only — inventory valuation, margin, accounting. */
  unitCost        Float                @default(0)
  /** Internal — amount owed to MSC when a partner sells this specimen (replaces the old "distributor price"). */
  settlementPrice Float?
  /** Suggested retail price for partners; they may charge more, subject to the location's min price policy. */
  msrp            Float?
  purchasedAt     DateTime             @default(now())
  supplier        String               @default("")
  notes           String               @default("")
  /** Actual amount the customer paid. Stored permanently, never overwritten. */
  salePrice       Float?
  soldAt          DateTime?
  salesChannel    SalesChannel?
  paymentMethod   PaymentMethod?
  /** Date sizeCm was last measured (intake, audit, or molt). */
  lastMeasuredAt  DateTime?
  /** Unguessable token behind the specimen QR code (open / audit / pickup / walk-in sale / report issue). */
  qrToken         String               @unique @default(cuid())
  orderId         String?
  order           Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderLineLinks  OrderLineSpecimen[]
  movements       InventoryMovement[]
  growthRecords   GrowthRecord[]
  moltEvents      MoltEvent[]
  auditItems      StoreAuditItem[]
  restockItems    RestockProposalItem[]
  settlementEntries SettlementEntry[]
  tasks           OperationsTask[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([productId, sizeCm, sex, price])
  @@index([status])
  @@index([locationType, locationId])
  @@index([soldAt])
  @@index([purchasedAt])
}

model InventoryMovement {
  id               String                @id @default(cuid())
  specimenId       String
  specimen         Specimen              @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  type             InventoryMovementType
  fromLocationType SpecimenLocationType?
  fromLocationId   String?
  toLocationType   SpecimenLocationType?
  toLocationId     String?
  amount           Float?
  salesChannel     SalesChannel?
  paymentMethod    PaymentMethod?
  notes            String                @default("")
  createdAt        DateTime              @default(now())

  @@index([specimenId])
  @@index([createdAt])
  @@index([type])
}

enum CouponType {
  percent
  fixed
}

enum MessageAuthor {
  customer
  staff
}

model Customer {
  id               String       @id @default(cuid())
  email            String       @unique
  passwordHash     String
  name             String
  phone            String       @default("")
  stripeCustomerId String?      @unique
  experience       Experience?
  referralCode     String       @unique @default(cuid())
  referredById     String?
  referredBy       Customer?    @relation("CustomerReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        Customer[]   @relation("CustomerReferrals")
  savedCart        Json?
  prefMethod           FulfillmentMethod?
  prefPickupId         String?
  prefPickupSubtype    String?
  prefMetroStationId   String?
  prefMetroLine        String?
  prefMeetupZoneId     String?
  prefMeetupAvailability String?
  prefCustomMeetup     String?
  prefOrderNotes       String       @default("")
  notifyStock          Boolean      @default(true)
  notifyPromos         Boolean      @default(true)
  notifyCare           Boolean      @default(false)
  addresses        Address[]
  orders           Order[]
  wishlist         WishlistItem[]
  arrivalAlerts    ArrivalAlert[]
  savedGuides      SavedCareGuide[]
  reviews          ProductReview[]
  coupons          Coupon[]
  orderMessages    OrderMessage[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([phone])
  @@index([referredById])
}

model WishlistItem {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId   String
  unitKey     String   @default("")
  notifyStock Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([customerId, productId, unitKey])
  @@index([customerId])
  @@index([productId])
}

model ArrivalAlert {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String?
  genus      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([productId])
  @@index([genus])
}

model SavedCareGuide {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  guideSlug  String
  createdAt  DateTime @default(now())

  @@unique([customerId, guideSlug])
  @@index([customerId])
}

model ProductReview {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  orderId    String?
  rating     Int
  comment    String   @default("")
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([productId])
}

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Float
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  referrerId String?
  maxUses    Int?
  usedCount  Int        @default(0)
  expiresAt  DateTime?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())

  @@index([customerId])
  @@index([referrerId])
}

model OrderMessage {
  id         String        @id @default(cuid())
  orderId    String
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author     MessageAuthor
  body       String
  createdAt  DateTime      @default(now())

  @@index([orderId])
  @@index([customerId])
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String   @default("Home")
  line1      String
  city       String
  postal     String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Order {
  id              String            @id @default(cuid())
  orderNumber     String            @unique
  customerId      String?
  customer        Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  stripeSessionId String?           @unique
  /** Needed for automatic refunds (no-show / cancellation). */
  stripePaymentIntentId String?
  email           String
  name            String
  phone           String
  method          FulfillmentMethod
  status          OrderStatus       @default(processing)
  statusDetail    String            @default("")
  couponCode      String?
  discountAmount  Float             @default(0)
  subtotal        Float
  deliveryFee     Float             @default(0)
  tax             Float             @default(0)
  total           Float
  notes           String            @default("")
  address         String?
  city            String?
  postal          String?
  zoneId          String?
  pickupId        String?
  /** pickup_point | metro_meetup | custom_meetup — only when method = pickup */
  pickupSubtype   String?
  metroStationId  String?
  metroLine       String?
  meetupZoneId    String?
  meetupAvailability String?
  customMeetupRequest String?
  locale          String            @default("en")
  salesChannel    SalesChannel      @default(web)
  paymentMethod   PaymentMethod     @default(stripe)
  lines           OrderLine[]
  specimens       Specimen[]
  messages        OrderMessage[]
  fulfillment     Fulfillment?
  tasks           OperationsTask[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
}

model OrderLine {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  /** @deprecated legacy tier key — kept for old rows, no longer written by new code. */
  sizeKey     String?
  nameEn      String
  nameFr      String
  /** Exact leg span in cm bought on this line (new specimen-based model). */
  sizeCm      Float?
  sex         SpecimenSex?
  sizeLabelEn String
  sizeLabelFr String
  qty         Int
  unitPrice   Float
  specimens   OrderLineSpecimen[]

  @@index([orderId])
}

/** Links each sold unit on an order line to a specific specimen (FIFO or manual). */
model OrderLineSpecimen {
  id          String   @id @default(cuid())
  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  specimenId  String
  specimen    Specimen @relation(fields: [specimenId], references: [id], onDelete: Restrict)

  @@unique([specimenId])
  @@index([orderLineId])
}

// ---------------------------------------------------------------------------
// Fulfillment — everything after payment until physical delivery
// ---------------------------------------------------------------------------

enum FulfillmentStatus {
  /** Order paid, specimens allocated — not yet being prepared. */
  pending
  /** MSC is preparing the specimen (packing / transferring to pickup point). */
  preparing
  /** Ready to collect — the pickup window clock is running. */
  ready
  /** Customer collected — specimens delivered, order complete. */
  completed
  /** Customer never collected within the window. */
  no_show
  /** Cancelled (manually or after a no-show). */
  cancelled
}

/**
 * One fulfillment record per paid order. Separate from the Order (the purchase)
 * and from Inventory (the specimens): tracks pickup/meetup preparation,
 * confirmation, reminders, no-shows and refunds.
 */
model Fulfillment {
  id              String            @id @default(cuid())
  orderId         String            @unique
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status          FulfillmentStatus @default(pending)
  /** Pickup point / partner location, when the order collects at a StoreLocation. */
  locationId      String?
  location        StoreLocation?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  /** Agreed pickup / meetup moment, when scheduled. */
  scheduledFor    DateTime?
  /** When the order became ready to collect (starts the no-show window). */
  readyAt         DateTime?
  /** Deadline after which the order is treated as a no-show. */
  collectBy       DateTime?
  remindersSent   Int               @default(0)
  lastReminderAt  DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  noShowAt        DateTime?
  /** Stripe refund id when a refund was issued. */
  stripeRefundId  String?
  refundedAt      DateTime?
  refundAmount    Float?
  /** Optional fee retained on no-show refunds. */
  noShowFee       Float             @default(0)
  /** Unguessable token for the customer/partner pickup-confirmation page & QR. */
  pickupToken     String            @unique @default(cuid())
  notes           String            @default("")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([locationId])
  @@index([collectBy])
}

// ---------------------------------------------------------------------------
// Growth tracking & molting — the specimen changes, its identity doesn't
// ---------------------------------------------------------------------------

enum GrowthSource {
  intake
  manual
  molt
  audit
}

/** Point-in-time size measurement. Current size lives on Specimen.sizeCm. */
model GrowthRecord {
  id         String       @id @default(cuid())
  specimenId String
  specimen   Specimen     @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  measuredAt DateTime     @default(now())
  sizeCm     Float
  source     GrowthSource @default(manual)
  notes      String       @default("")
  createdAt  DateTime     @default(now())

  @@index([specimenId, measuredAt])
}

/** Biological molt event — updates current size, never specimen identity. */
model MoltEvent {
  id                String   @id @default(cuid())
  specimenId        String
  specimen          Specimen @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  moltedAt          DateTime @default(now())
  previousSizeCm    Float
  newSizeEstimateCm Float
  notes             String   @default("")
  createdAt         DateTime @default(now())

  @@index([specimenId, moltedAt])
}

// ---------------------------------------------------------------------------
// Store audits — expected vs actual inventory at partner locations
// ---------------------------------------------------------------------------

enum AuditItemResult {
  found
  missing
  /** Not physically present because the partner already sold it without registering the sale. */
  sold
}

model StoreAudit {
  id         String           @id @default(cuid())
  locationId String
  location   StoreLocation    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  auditedAt  DateTime         @default(now())
  /** Name of the MSC employee who performed the visit. */
  employee   String
  notes      String           @default("")
  /** Filled on completion — snapshot counts for quick listing. */
  expectedCount Int           @default(0)
  foundCount    Int           @default(0)
  missingCount  Int           @default(0)
  /** Discovered sold during the visit — inventory + settlement already applied, not an open investigation. */
  soldCount     Int           @default(0)
  items      StoreAuditItem[]
  tasks      OperationsTask[]
  createdAt  DateTime         @default(now())

  @@index([locationId, auditedAt])
}

model StoreAuditItem {
  id          String          @id @default(cuid())
  auditId     String
  audit       StoreAudit      @relation(fields: [auditId], references: [id], onDelete: Cascade)
  specimenId  String
  specimen    Specimen        @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  result      AuditItemResult
  /** Size measured during the visit (updates the specimen's current size). */
  sizeCm      Float?
  healthNotes String          @default("")
  notes       String          @default("")
  photoUrl    String?
  /** Price the partner reported for a `sold` result — mirrors the specimen's recorded salePrice. */
  salePrice     Float?
  paymentMethod PaymentMethod?

  @@unique([auditId, specimenId])
  @@index([specimenId])
}

// ---------------------------------------------------------------------------
// Restock proposals — replacement inventory is never sent automatically
// ---------------------------------------------------------------------------

enum RestockProposalStatus {
  draft
  /** Sent to the partner for confirmation. */
  sent
  confirmed
  declined
  /** Specimens are on their way to the partner. */
  in_transit
  completed
  cancelled
}

model RestockProposal {
  id            String                @id @default(cuid())
  locationId    String
  location      StoreLocation         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  status        RestockProposalStatus @default(draft)
  reason        String                @default("")
  preferredDate DateTime?
  /** Unguessable token for the partner confirmation page. */
  confirmToken  String                @unique @default(cuid())
  sentAt        DateTime?
  confirmedAt   DateTime?
  declinedAt    DateTime?
  shippedAt     DateTime?
  completedAt   DateTime?
  partnerNotes  String                @default("")
  items         RestockProposalItem[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([locationId, status])
}

model RestockProposalItem {
  id         String          @id @default(cuid())
  proposalId String
  proposal   RestockProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  /** Suggested concrete specimen from the warehouse. */
  specimenId String
  specimen   Specimen        @relation(fields: [specimenId], references: [id], onDelete: Cascade)
  notes      String          @default("")

  @@unique([proposalId, specimenId])
  @@index([specimenId])
}

// ---------------------------------------------------------------------------
// Settlement ledger — partner finances come from records, never from inventory
// ---------------------------------------------------------------------------

enum SettlementPaymentStatus {
  pending
  /** Included in a monthly statement sent to the partner. */
  invoiced
  paid
}

/** One entry per partner sale — the financial source of truth for partner balances. */
model SettlementEntry {
  id              String                  @id @default(cuid())
  locationId      String
  location        StoreLocation           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  specimenId      String                  @unique
  specimen        Specimen                @relation(fields: [specimenId], references: [id], onDelete: Restrict)
  soldAt          DateTime                @default(now())
  /** What the partner charged the customer. */
  salePrice       Float
  /** What the partner owes MSC for this specimen. */
  settlementPrice Float
  /** salePrice − settlementPrice, kept by the partner. */
  partnerMargin   Float
  paymentStatus   SettlementPaymentStatus @default(pending)
  statementId     String?
  statement       SettlementStatement?    @relation(fields: [statementId], references: [id], onDelete: SetNull)
  notes           String                  @default("")
  createdAt       DateTime                @default(now())

  @@index([locationId, paymentStatus])
  @@index([soldAt])
}

enum StatementStatus {
  draft
  sent
  paid
}

/** Monthly partner statement generated from ledger entries. */
model SettlementStatement {
  id          String            @id @default(cuid())
  locationId  String
  location    StoreLocation     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  totalSales  Float             @default(0)
  totalOwed   Float             @default(0)
  totalMargin Float             @default(0)
  status      StatementStatus   @default(draft)
  sentAt      DateTime?
  paidAt      DateTime?
  entries     SettlementEntry[]
  createdAt   DateTime          @default(now())

  @@unique([locationId, periodStart, periodEnd])
  @@index([locationId])
}

// ---------------------------------------------------------------------------
// Internal operations tasks — manual decisions surfaced to the MSC team
// ---------------------------------------------------------------------------

enum TaskType {
  /** Decide what to do with a specimen after a no-show (leave at partner / return / transfer). */
  no_show_disposition
  /** Investigate a specimen missing during an audit. */
  audit_investigation
  inventory_correction
  restock_approval
  general
}

enum TaskStatus {
  open
  in_progress
  done
  dismissed
}

model OperationsTask {
  id         String        @id @default(cuid())
  type       TaskType      @default(general)
  status     TaskStatus    @default(open)
  title      String
  details    String        @default("")
  specimenId String?
  specimen   Specimen?     @relation(fields: [specimenId], references: [id], onDelete: SetNull)
  locationId String?
  location   StoreLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  orderId    String?
  order      Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  auditId    String?
  audit      StoreAudit?   @relation(fields: [auditId], references: [id], onDelete: SetNull)
  dueAt      DateTime?
  resolution String        @default("")
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status, type])
  @@index([locationId])
}

// ---------------------------------------------------------------------------
// Notification service — business modules never send email directly
// ---------------------------------------------------------------------------

enum EmailStatus {
  sent
  failed
  /** Email intentionally not delivered (e.g. Resend not configured, missing recipient). */
  skipped
}

/** Audit log of every email the Notification Service attempted. */
model EmailLog {
  id         String      @id @default(cuid())
  /** Template id from the template registry (e.g. "pickup-ready"). */
  templateId String
  /** Business event that triggered the send (e.g. "fulfillment.ready"). */
  event      String      @default("")
  to         String
  subject    String
  status     EmailStatus
  error      String      @default("")
  /** Business context: orderId, specimenId, locationId, … */
  context    Json        @default("{}")
  createdAt  DateTime    @default(now())

  @@index([templateId])
  @@index([to])
  @@index([createdAt])
}
