// Montreal Spider Co. — database schema (Neon Postgres)
// Run `npx prisma generate` after changes, and `npx prisma migrate deploy`
// (or `npx prisma db push`) to apply to your database. See SETUP_DATABASE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Experience {
  beginner
  intermediate
  advanced
}

enum SpiderType {
  terrestrial
  arboreal
  fossorial
}

enum Temperament {
  docile
  skittish
  defensive
}

/** Reusable species profile — fill once, reuse across listings. */
model Species {
  id            String       @id @default(cuid())
  scientific    String       @unique
  commonEn      String
  commonFr      String       @default("")
  genus         String
  experience    Experience
  type          SpiderType
  temperament   Temperament
  hue           Int          @default(36)
  accent        String       @default("#c9a24b")
  image         String?
  adultSizeEn   String       @default("")
  adultSizeFr   String       @default("")
  growthEn      String       @default("")
  growthFr      String       @default("")
  originEn      String       @default("")
  originFr      String       @default("")
  lifespanEn    String       @default("")
  lifespanFr    String       @default("")
  humidity      String       @default("")
  temperature   String       @default("")
  enclosureEn   String       @default("")
  enclosureFr   String       @default("")
  dietEn        String       @default("")
  dietFr        String       @default("")
  descriptionEn String       @default("")
  descriptionFr String       @default("")
  careGuide     String?
  products      Product[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([genus])
  @@index([commonEn])
}

model Product {
  id            String       @id @default(cuid())
  slug          String       @unique
  scientific    String
  speciesId     String?
  species       Species?     @relation(fields: [speciesId], references: [id], onDelete: SetNull)
  commonEn      String
  commonFr      String
  genus         String
  experience    Experience
  type          SpiderType
  temperament   Temperament
  featured      Boolean      @default(false)
  newArrival    Boolean      @default(false)
  rating        Float        @default(5)
  reviews       Int          @default(0)
  hue           Int          @default(36)
  accent        String       @default("#c9a24b")
  image         String?
  adultSizeEn   String       @default("")
  adultSizeFr   String       @default("")
  growthEn      String       @default("")
  growthFr      String       @default("")
  originEn      String       @default("")
  originFr      String       @default("")
  lifespanEn    String       @default("")
  lifespanFr    String       @default("")
  humidity      String       @default("")
  temperature   String       @default("")
  enclosureEn   String       @default("")
  enclosureFr   String       @default("")
  dietEn        String       @default("")
  dietFr        String       @default("")
  descriptionEn String       @default("")
  descriptionFr String       @default("")
  careGuide     String?
  arrived       DateTime     @default(now())
  sizes         ProductSize[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([experience])
  @@index([genus])
  @@index([speciesId])
}

model ProductSize {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  key       String
  labelEn   String
  labelFr   String
  price     Float
  stock     Int     @default(0)
  position  Int     @default(0)

  @@index([productId])
}

model PickupPoint {
  id           String   @id @default(cuid())
  name         String
  neighborhood String   @default("")
  address      String
  /** Weekly schedule — { mon: { open, close } | { closed: true }, … } */
  hours        Json     @default("{}")
  mapsUrl      String   @default("")
  phone        String   @default("")
  position     Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/** Bilingual key/value store for store policies (pickup terms, T&C). */
model Setting {
  key     String @id
  valueEn String @default("")
  valueFr String @default("")
}

/** Key/value store for admin-managed site options (e.g. default product photo). */
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/** Reusable species photos uploaded from the admin — searchable when assigning product images. */
model SpeciesLibraryImage {
  id         String   @id @default(cuid())
  url        String
  label      String   @default("")
  scientific String   @default("")
  genus      String   @default("")
  slug       String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())

  @@index([scientific])
  @@index([genus])
  @@index([label])
}

// ---------------------------------------------------------------------------
// Customers, orders & checkout (production)
// ---------------------------------------------------------------------------

enum OrderStatus {
  processing
  ready
  delivered
  cancelled
}

enum FulfillmentMethod {
  delivery
  pickup
}

model Customer {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  name             String
  phone            String    @default("")
  stripeCustomerId String?   @unique
  addresses        Address[]
  orders           Order[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([phone])
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String   @default("Home")
  line1      String
  city       String
  postal     String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Order {
  id              String            @id @default(cuid())
  orderNumber     String            @unique
  customerId      String?
  customer        Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  stripeSessionId String?           @unique
  email           String
  name            String
  phone           String
  method          FulfillmentMethod
  status          OrderStatus       @default(processing)
  subtotal        Float
  deliveryFee     Float             @default(0)
  tax             Float             @default(0)
  total           Float
  notes           String            @default("")
  address         String?
  city            String?
  postal          String?
  zoneId          String?
  pickupId        String?
  locale          String            @default("en")
  lines           OrderLine[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
}

model OrderLine {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  sizeKey     String
  nameEn      String
  nameFr      String
  sizeLabelEn String
  sizeLabelFr String
  qty         Int
  unitPrice   Float

  @@index([orderId])
}
